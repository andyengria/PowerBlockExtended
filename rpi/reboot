#!/usr/bin/env bash
set -euo pipefail

CHIP=0
STATUS_PIN=17
REAL_SYSTEMCTL="/usr/bin/systemctl"

# Free BCM17 if the standard powerblock service still owns it
pkill -f /usr/bin/powerblockservice >/dev/null 2>&1 || true
pkill gpioset >/dev/null 2>&1 || true

# Send reboot-intent pulse
/usr/bin/gpioset -c "$CHIP" \
  -t 200ms,500ms,300ms,300ms,300ms,300ms,300ms,300ms,300ms,300ms,0 \
  "$STATUS_PIN=1"

# Give the ATtiny time to latch the pulse
/bin/sleep 0.3

exec "$REAL_SYSTEMCTL" reboot
